# GiveBlack – Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
#
# Required for: API server (apps/api), Mobile app (EXPO_PUBLIC_*), Admin panel

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=5001
API_HOST=0.0.0.0

# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://giveblack_user:YOUR_PASSWORD@localhost:5432/giveblack_db

# ── Auth (JWT) ─────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-very-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-very-long-random-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ── CORS ───────────────────────────────────────────────────
# Comma-separated origins. Production: primary app origin(s).
CORS_ORIGINS=https://giveblackapp.com,https://www.giveblackapp.com

# ── Mobile App (Expo) ─────────────────────────────────────
# Domain used for links and Stripe redirects (no https://)
EXPO_PUBLIC_DOMAIN=giveblackapp.com
# API base (Nginx serves Fastify under /app → paths like /app/api/...).
# Stripe webhook: https://giveblackapp.com/app/api/webhooks/stripe
EXPO_PUBLIC_API_URL=https://giveblackapp.com/app

# ── OAuth — API (apps/api) ─────────────────────────────────
# Comma-separated Google OAuth client IDs whose id_token audience must match (include the Web client used for id_token aud, plus iOS/Android as needed).
# Example (match lib/google-signin-config.ts): ...ic0otulkht3m258h9utqake2m0unirlu.apps.googleusercontent.com,...67gnhk1b900k459o28hm2g6rvmvov482.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_IDS=your-web-client.apps.googleusercontent.com,your-ios-client.apps.googleusercontent.com,your-android-client.apps.googleusercontent.com
# Sign in with Apple: usually the iOS bundle id (e.g. com.giveblack.app).
APPLE_CLIENT_ID=com.giveblack.app
# ── OAuth — Expo (Google native clients are in lib/google-signin-config.ts, not env) ──
# Optional: override iOS URL scheme / client id for app.config.js prebuild only (must match google-signin-config if set).
# EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Apple / Google verbose logs in dev or TestFlight when set to 1
# EXPO_PUBLIC_DEBUG_AUTH=1
# ── Admin Panel (Vite; baked in at build — use root `npm run build:admin` or deploy script) ──
VITE_API_URL=https://giveblackapp.com/app
# Site origin for admin deep links in API emails (SPA path is always /admin/...).
ADMIN_PANEL_URL=https://giveblackapp.com

# ── Admin Bootstrap (first db init only) ───────────────────
ADMIN_BOOTSTRAP_PASSWORD=Admin@123

# ── Stripe ─────────────────────────────────────────────────
# From your Stripe Dashboard > Developers > API Keys
 STRIPE_PRICE_GROWTH=price_1TA2CPBk2z7Pp8h03aNgWKxt
 STRIPE_PRICE_INSTITUTIONAL=price_1TA2DnBk2z7Pp8h0GFcDMfQ3
 STRIPE_SECRET_KEY=sk_test_P1OxcjJO3wysUs9AZGE6bGtz00PWILWduN
 STRIPE_PUBLISHABLE_KEY=pk_test_8mIgwWbS6W8joKgFApfLnpS100PMeznjsQ
 STRIPE_WEBHOOK_SECRET=whsec_EWo91lrdULI3uSxw9Rrgfr2gt8feislT

# ── Payment anti-abuse / Cloudflare Turnstile ─────────────
# Cloudflare Dashboard → Turnstile → Add site. Site key is safe for frontend use;
# secret key must remain server-only.
CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAA...
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAA...
# Expo web/client builds need the public key with an EXPO_PUBLIC_ prefix.
EXPO_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAA...
# Admin Vite public campaign page also needs the public key.
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAA...
# Optional: separate HMAC secret for short-lived donation session tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PAYMENT_SECURITY_TOKEN_SECRET=replace-with-very-long-random-secret-min-32-chars
PAYMENT_DONATION_SESSION_TTL_SECONDS=600
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_LIMIT_IP_LIMIT=12
PAYMENT_RATE_LIMIT_IDENTITY_LIMIT=6
# Stricter caps for /api/payments/donation-session, guest checkout, and public checkout (unauthenticated Stripe creates).
PAYMENT_RATE_LIMIT_STRICT_IP_LIMIT=6
PAYMENT_RATE_LIMIT_STRICT_IDENTITY_LIMIT=3
PAYMENT_FAILED_ATTEMPT_LIMIT=5
# Log-only heuristics: many sub-threshold gifts from one IP (does not block by amount alone).
PAYMENT_VELOCITY_LOW_USD_MAX=2
PAYMENT_VELOCITY_LOW_IP_TOTAL_MIN=18
PAYMENT_VELOCITY_LOW_IP_LOW_COUNT_MIN=14
# Development only: allows donation-session creation without Turnstile keys.
# Never set this to 1 in production.
CLOUDFLARE_TURNSTILE_DEV_BYPASS=0

# ── Cloudflare R2 (user uploads — charity logos, campaign images, profile photos) ──
# Cloudflare dashboard → R2 → bucket → Settings (S3 API + API token).
# When all five values are set the API uploads to R2 instead of local disk.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=giveblack-uploads
R2_PUBLIC_URL=https://images.giveblackapp.com
# Optional override; auto-derived from R2_ACCOUNT_ID when blank.
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ── Email (Brevo, optional) ────────────────────────────────
# Brevo: app.brevo.com → Settings → SMTP & API → API keys (v3). Sender must be verified (Senders & IP).
BREVO_API_KEY=xkeysib-replace-with-your-brevo-v3-api-key
BREVO_SENDER_EMAIL=support@giveblackapp.com
BREVO_SENDER_NAME=GiveBlack
# BCC for admin copies (charity approve/reject emails)
ADMIN_EMAIL=mazu@mawamedia.com
# Branding – landing site & contact (used in all transactional emails)
APP_URL=https://giveblackapp.com
SUPPORT_EMAIL=info@giveblackapp.com
# Logo in emails (optional; if not set, "GiveBlack" wordmark is used)
# EMAIL_LOGO_URL=https://yoursite.com/logo-email.png

# ── Push Notifications (Expo, optional) ────────────────────
# EXPO_ACCESS_TOKEN=expo-token-here

# ── Campaign thank-you page (optional; defaults used if unset) ──
# APP_STORE_URL=https://apps.apple.com/app/...
# PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...
# DONOR_LOGIN_WEB_URL=https://giveblackapp.com/
