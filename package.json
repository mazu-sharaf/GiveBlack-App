{
  "name": "expo-app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "npm run -w @giveblack/api build",
    "server:prod": "NODE_ENV=production node apps/api/dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "npx expo start",
    "start:tunnel": "npx expo start --tunnel",
    "dev:admin": "cd apps/admin && npm run dev",
    "api:dev": "npm run -w @giveblack/api dev",
    "api:build": "npm run -w @giveblack/api build",
    "api:start": "npm run -w @giveblack/api start",
    "api:db:init": "npm run -w @giveblack/api db:init",
    "gen:module": "node scripts/gen-module.mjs",
    "build:admin": "cd apps/admin && npm run build",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "check": "npx expo-doctor && npx expo lint && npm run api:build",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@fastify/http-proxy": "^11.4.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@stripe/stripe-js": "^8.9.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@tanstack/react-query": "^5.83.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@ungap/structured-clone": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "sharp": "^0.34.5",
    "stripe": "^20.4.0",
    "tsx": "^4.21.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/react": "~19.1.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
